# Lab 6 environment template
# Copy to .env for local development and fill in real values.
# In Netlify/AWS Amplify, add these same keys in environment settings.

# OpenWeather API
VITE_OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE
VITE_OPENWEATHER_UNITS=metric

# Frontend -> serverless endpoint base
VITE_FUNCTIONS_BASE=/.netlify/functions

# Access code shown/used on frontend Messages view
VITE_MESSAGES_ACCESS_CODE=YOUR_MESSAGES_ACCESS_CODE_HERE

# Access code validated by the serverless function
MESSAGES_ACCESS_CODE=YOUR_MESSAGES_ACCESS_CODE_HERE
